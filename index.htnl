                    <button onclick="switchTradeMode('spot')" class="trading-tab flex-1 py-3 text-sm font-medium text-center" data-mode="spot">Spot</button>
                    <button onclick="switchTradeMode('margin')" class="trading-tab flex-1 py-3 text-sm font-medium text-center" data-mode="margin">Margin</button>
                    <button onclick="switchTradeMode('p2p')" class="trading-tab flex-1 py-3 text-sm font-medium text-center" data-mode="p2p">P2P</button>
                </div>

                <!-- Futures Trading -->
                <div id="trade-futures" class="trade-mode-content active">
                    <div class="glass border-b border-border p-3">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2">
                                <button onclick="openPairSelector()" class="flex items-center gap-2">
                                    <span id="futures-pair-name" class="text-white font-bold text-lg">BTCUSDT</span>
                                    <i class="fas fa-chevron-down text-textGray text-xs"></i>
                                </button>
                                <span class="text-xs text-textGray">Perpetual</span>
                                <span id="futures-change" class="text-tradeRed text-sm font-medium">-1.96%</span>
                            </div>
                            <div class="flex items-center gap-3">
                                <button class="text-textGray hover:text-primary"><i class="fas fa-star"></i></button>
                                <button class="text-textGray hover:text-primary"><i class="fas fa-chart-bar"></i></button>
                                <button class="text-textGray hover:text-primary"><i class="fas fa-ellipsis-v"></i></button>
                            </div>
                        </div>
                        <div class="flex items-center gap-4 mt-3">
                            <button onclick="openMarginModeModal()" class="flex items-center gap-1 text-sm text-textGray hover:text-white">
                                <span id="margin-mode-display">Cross</span><i class="fas fa-chevron-down text-xs"></i>
                            </button>
                            <button onclick="openLeverageModal()" class="flex items-center gap-1 text-sm text-primary">
                                <span id="leverage-display">10x</span><i class="fas fa-chevron-down text-xs"></i>
                            </button>
                        </div>
                    </div>

                    <div class="flex border-b border-border">
                        <button onclick="switchPositionTab('open')" class="flex-1 py-2 text-sm font-medium text-center text-white border-b-2 border-primary">Open</button>
                        <button onclick="switchPositionTab('close')" class="flex-1 py-2 text-sm font-medium text-center text-textGray border-b-2 border-transparent">Close</button>
                    </div>

                    <div class="grid grid-cols-5 gap-2 p-3">
                        <div class="col-span-3 space-y-3">
                            <div class="order-type-dropdown relative">
                                <button onclick="toggleOrderTypeMenu()" class="flex items-center gap-2 text-sm text-white">
                                    <i class="fas fa-dot-circle text-primary text-xs"></i>
                                    <span id="order-type-label">Limit</span>
                                    <i class="fas fa-chevron-down text-textGray text-xs"></i>
                                </button>
                                <div id="order-type-menu" class="order-type-menu">
                                    <div class="order-type-item active" onclick="selectOrderType('limit')">Limit</div>
                                    <div class="order-type-item" onclick="selectOrderType('market')">Market</div>
                                    <div class="order-type-item" onclick="selectOrderType('stop')">Stop</div>
                                    <div class="order-type-item" onclick="selectOrderType('trailing')">Trailing Stop</div>
                                    <div class="order-type-item" onclick="selectOrderType('scaled')">Scaled Order</div>
                                    <div class="order-type-item" onclick="selectOrderType('iceberg')">Iceberg</div>
                                    <div class="order-type-item" onclick="selectOrderType('twap')">TWAP</div>
                                </div>
                            </div>

                            <div class="flex gap-2">
                                <select class="input-trade flex-1 text-sm"><option>Counterparty 1</option><option>Counterparty 2</option></select>
                                <button class="px-3 py-2 border border-border rounded-lg text-sm font-medium hover:border-primary">BBO</button>
                            </div>

                            <div class="relative">
                                <input type="number" id="futures-price" class="input-trade" placeholder="Price" value="67982.03">
                                <span class="absolute right-3 top-1/2 -translate-y-1/2 text-textGray text-xs">USDT</span>
                            </div>

                            <div class="relative">
                                <input type="number" id="futures-quantity" class="input-trade" placeholder="Quantity">
                                <span class="absolute right-3 top-1/2 -translate-y-1/2 text-textGray text-xs">BTC</span>
                            </div>

                            <div class="flex gap-1">
                                <button onclick="setFuturesPercent(10)" class="percent-btn flex-1">10%</button>
                                <button onclick="setFuturesPercent(25)" class="percent-btn flex-1">25%</button>
                                <button onclick="setFuturesPercent(50)" class="percent-btn flex-1">50%</button>
                                <button onclick="setFuturesPercent(75)" class="percent-btn flex-1">75%</button>
                                <button onclick="setFuturesPercent(100)" class="percent-btn flex-1">100%</button>
                            </div>

                            <div class="flex items-center gap-2">
                                <input type="checkbox" id="tp-sl-check" class="tp-sl-checkbox" onchange="toggleTPSL()">
                                <label for="tp-sl-check" class="text-sm text-textGray">TP/SL</label>
                            </div>

                            <div id="tp-sl-section" class="hidden space-y-2">
                                <div class="flex gap-2 items-center">
                                    <input type="number" class="input-trade flex-1 text-sm" placeholder="Take Profit">
                                    <span class="text-textGray text-xs">%</span>
                                </div>
                                <div class="flex gap-2 items-center">
                                    <input type="number" class="input-trade flex-1 text-sm" placeholder="Stop Loss">
                                    <span class="text-textGray text-xs">%</span>
                                </div>
                            </div>

                            <div class="flex justify-between text-xs text-textGray">
                                <span>Available</span>
                                <span id="futures-available-balance" class="font-mono">0.00 USDT</span>
                            </div>
                            <div class="flex justify-between text-xs text-textGray">
                                <span>Max Open</span>
                                <span id="futures-max-open" class="font-mono">0.00 BTC</span>
                            </div>

                            <button onclick="placeFuturesOrder('buy')" class="btn-animated w-full long-btn py-3 rounded-lg">
                                <div class="font-bold">Open Long</div>
                                <div class="text-xs opacity-80" id="long-cost">0.00 USDT</div>
                            </button>
                            <button onclick="placeFuturesOrder('sell')" class="btn-animated w-full short-btn py-3 rounded-lg">
                                <div class="font-bold">Open Short</div>
                                <div class="text-xs opacity-80" id="short-cost">0.00 USDT</div>
                            </button>
                        </div>

                        <div class="col-span-2">
                            <div class="text-right text-xs text-textGray mb-1"><span class="mr-4">Price (USDT)</span><span>Qty (BTC)</span></div>
                            <div id="order-book-sells" class="space-y-0.5 mb-2"></div>
                            <div id="order-book-current" class="text-center py-2 text-lg font-bold font-mono">67,982.03</div>
                            <div id="order-book-buys" class="space-y-0.5"></div>
                            <div class="mt-3 flex items-center justify-between text-xs">
                                <span class="text-textGray">B 51%</span>
                                <div class="flex-1 mx-2 h-1 bg-surfaceLight rounded-full overflow-hidden"><div class="h-full bg-tradeGreen" style="width: 51%"></div></div>
                                <span class="text-textGray">49% S</span>
                            </div>
                        </div>
                    </div>

