                            <button onclick="switchTradeBottomTab('orders')" class="flex-1 py-3 text-sm font-medium text-center text-textGray border-b-2 border-transparent">Orders(0)</button>
                            <button onclick="switchTradeBottomTab('bots')" class="flex-1 py-3 text-sm font-medium text-center text-textGray border-b-2 border-transparent">Bots (0)</button>
                            <button onclick="switchTradeBottomTab('assets')" class="flex-1 py-3 text-sm font-medium text-center text-textGray border-b-2 border-transparent">Assets</button>
