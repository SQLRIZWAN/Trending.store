        <!-- Main Content -->
        <main class="main-content">
            <!-- Home View -->
            <div id="view-home" class="view-section animate-fade-in">
                <div class="grid grid-cols-2 gap-3 p-4">
                    <div class="glass rounded-xl p-4">
                        <p class="text-textGray text-xs mb-1">NFT Value</p>
                        <h2 id="nft-value" class="text-xl font-bold font-mono text-purple-400">₹0.00</h2>
                        <p class="text-textGray text-xs mt-1">Your NFT Holdings</p>
                    </div>
                    <div class="glass rounded-xl p-4">
                        <p class="text-textGray text-xs mb-1">Invest Value</p>
                        <h2 id="invest-value" class="text-xl font-bold font-mono text-primary">₹0.00</h2>
                        <p class="text-textGray text-xs mt-1">Active Investments</p>
                    </div>
                    <div class="glass-gold rounded-xl p-4 col-span-2">
                        <p class="text-textGray text-xs mb-1">Total Balance</p>
                        <h2 id="total-balance-display" class="text-3xl font-bold font-mono text-primary">₹0.00</h2>
                        <p class="text-textGray text-xs mt-1">All Accounts Combined</p>
                    </div>
                </div>
                <div class="flex gap-3 px-4 mb-6">
                    <button onclick="openPay()" class="btn-animated flex-1 btn-gold py-3 rounded-lg"><i class="fas fa-arrow-down mr-2"></i>Deposit</button>
                    <button onclick="openWithdrawModal()" class="btn-animated flex-1 bg-surfaceLight border border-border text-white font-bold py-3 rounded-lg hover:border-primary"><i class="fas fa-arrow-up mr-2"></i>Withdraw</button>
                    <button onclick="navigateTo('transfer')" class="btn-animated flex-1 bg-surfaceLight border border-border text-white font-bold py-3 rounded-lg hover:border-primary"><i class="fas fa-exchange-alt mr-2"></i>Transfer</button>
                </div>
                <div class="px-4 mb-4">
                    <div class="flex items-center justify-between mb-3">
                        <h3 class="font-bold"><i class="fas fa-fire text-danger mr-2"></i>Trending</h3>
                        <button onclick="navigateTo('market')" class="text-primary text-sm hover:underline">View All</button>
                    </div>
                    <div id="trending-list" class="space-y-1"></div>
                </div>
            </div>

            <!-- Market View -->
            <div id="view-market" class="view-section hidden animate-fade-in">
                <div class="sticky top-[57px] bg-bgDeep z-40 border-b border-border p-3">
                    <div class="relative">
                        <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-textGray"></i>
                        <input type="text" id="market-search" class="input-trade pl-10" placeholder="Search cryptocurrency..." oninput="filterMarketSearch()">
                    </div>
                    <div class="flex items-center gap-2 mt-2 overflow-x-auto no-scrollbar">
                        <button onclick="filterMarket('all')" class="market-filter active px-4 py-2 rounded-full text-sm font-medium bg-primary text-black whitespace-nowrap">All</button>
                        <button onclick="filterMarket('gainers')" class="market-filter px-4 py-2 rounded-full text-sm font-medium bg-surfaceLight text-textGray whitespace-nowrap">Top Gainers</button>
                        <button onclick="filterMarket('losers')" class="market-filter px-4 py-2 rounded-full text-sm font-medium bg-surfaceLight text-textGray whitespace-nowrap">Top Losers</button>
                        <button onclick="filterMarket('volume')" class="market-filter px-4 py-2 rounded-full text-sm font-medium bg-surfaceLight text-textGray whitespace-nowrap">Volume</button>
                    </div>
                </div>
                <div class="p-2">
                    <div class="flex items-center justify-between text-textGray text-xs px-2 py-2 border-b border-border">
                        <span class="flex-1">Pair</span>
                        <span class="w-24 text-right">Price</span>
                        <span class="w-20 text-right">Change</span>
                    </div>
                    <div id="market-list" class="divide-y divide-border"></div>
                </div>
            </div>

            <!-- Trade View -->
