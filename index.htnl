                            <div class="glass rounded-xl p-4 flex items-center justify-between cursor-pointer hover:bg-surfaceLight transition-colors" onclick="switchWalletTab('invest')">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center"><i class="fas fa-chart-pie text-primary"></i></div>
                                    <div><p class="font-semibold">Invest Account</p><p class="text-textGray text-xs">Active Investments</p></div>
                                </div>
                                <span id="invest-balance-display" class="font-mono font-bold text-primary">₹0.00</span>
                            </div>
                        </div>
                    </div>
                    <div id="wallet-spot" class="wallet-content hidden"><div id="spot-assets" class="space-y-2"></div></div>
                    <div id="wallet-futures" class="wallet-content hidden"><div id="futures-positions-wallet" class="space-y-2"></div></div>
                    <div id="wallet-margin" class="wallet-content hidden"><div id="margin-positions-wallet" class="space-y-2"></div></div>
                    <div id="wallet-nft" class="wallet-content hidden">
                        <h3 class="font-bold mb-4">Your NFT Holdings</h3>
                        <div id="wallet-nft-list" class="grid grid-cols-2 gap-4"></div>
                    </div>
                    <div id="wallet-invest" class="wallet-content hidden">
                        <h3 class="font-bold mb-4">Your Active Investments</h3>
                        <div id="wallet-invest-list" class="space-y-3"></div>
                    </div>
                </div>
            </div>

            <!-- Profile View -->
            <div id="view-profile" class="view-section hidden animate-fade-in">
                <div class="p-4">
                    <div class="glass rounded-xl p-6 text-center mb-6">
                        <div class="relative inline-block mb-4">
                            <img id="profile-avatar" src="https://ui-avatars.com/api/?name=User&background=d4af37&color=000" class="w-24 h-24 rounded-full border-2 border-primary object-cover">
                            <label class="absolute bottom-0 right-0 w-8 h-8 bg-primary rounded-full flex items-center justify-center cursor-pointer btn-animated"><i class="fas fa-camera text-black text-xs"></i><input type="file" class="hidden" accept="image/*" onchange="updateAvatar(this)"></label>
                        </div>
                        <h2 id="profile-name" class="text-xl font-bold mb-1">User Name</h2>
                        <p id="profile-email" class="text-textGray text-sm">user@email.com</p>
                        <div id="kyc-profile-badge" class="inline-flex items-center gap-2 mt-2 px-3 py-1 rounded-full bg-surfaceLight text-xs"><i class="fas fa-shield-alt text-primary"></i><span id="kyc-badge-text">Unverified</span></div>
                        <button onclick="openEditProfile()" class="mt-4 px-4 py-2 bg-surfaceLight border border-border rounded-lg text-sm font-semibold text-primary w-full hover:border-primary"><i class="fas fa-edit mr-2"></i>Edit Profile</button>
                        <div class="grid grid-cols-3 gap-3 mt-6">
                            <div class="text-center p-3 bg-surface rounded-lg"><p class="text-textGray text-xs mb-1">Total Balance</p><p id="profile-total" class="font-bold font-mono text-sm text-primary">₹0</p></div>
                            <div class="text-center p-3 bg-surface rounded-lg"><p class="text-textGray text-xs mb-1">Crypto</p><p id="profile-crypto" class="font-bold font-mono text-sm mt-1 text-tradeGreen">₹0</p></div>
                            <div class="text-center p-3 bg-surface rounded-lg"><p class="text-textGray text-xs mb-1">Investments</p><p id="profile-invest" class="font-bold font-mono text-sm mt-1 text-primary">₹0</p></div>
                        </div>
                    </div>
                    <div class="space-y-3">
                        <button onclick="navigateTo('history')" class="w-full glass rounded-xl p-4 flex items-center justify-between btn-animated hover:bg-surfaceLight"><div class="flex items-center gap-3"><i class="fas fa-history text-primary"></i><span>Transaction History</span></div><i class="fas fa-chevron-right text-textGray"></i></button>
                        <button onclick="navigateTo('transfer')" class="w-full glass rounded-xl p-4 flex items-center justify-between btn-animated hover:bg-surfaceLight"><div class="flex items-center gap-3"><i class="fas fa-exchange-alt text-primary"></i><span>Internal Transfer</span></div><i class="fas fa-chevron-right text-textGray"></i></button>
                        <button onclick="navigateTo('kyc')" class="w-full glass rounded-xl p-4 flex items-center justify-between btn-animated hover:bg-surfaceLight"><div class="flex items-center gap-3"><i class="fas fa-id-card text-primary"></i><span>Identity Verification</span></div><span id="kyc-status-badge" class="kyc-status-badge kyc-status-pending">Unverified</span></button>
                    </div>
                </div>
            </div>

            <!-- Orders History View -->
            <div id="view-orders" class="view-section hidden animate-fade-in">
                <div class="sticky top-[57px] bg-bgDeep z-40 border-b border-border">
                    <div class="flex">
                        <button onclick="switchOrderTab('open')" class="flex-1 py-3 text-sm font-medium text-center border-b-2 border-primary text-white">Open Orders</button>
                        <button onclick="switchOrderTab('history')" class="flex-1 py-3 text-sm font-medium text-center border-b-2 border-transparent text-textGray">Order History</button>
                    </div>
                </div>
                <div id="orders-content" class="p-4 space-y-2"><p class="text-textGray text-center py-8">Loading orders...</p></div>
            </div>

            <!-- History View -->
            <div id="view-history" class="view-section hidden animate-fade-in">
                <div class="sticky top-[57px] bg-bgDeep z-40 border-b border-border">
                    <div class="flex">
                        <button onclick="switchHistoryTab('all')" class="flex-1 py-3 text-sm font-medium text-center border-b-2 border-primary text-white">All</button>
                        <button onclick="switchHistoryTab('deposit')" class="flex-1 py-3 text-sm font-medium text-center border-b-2 border-transparent text-textGray">Deposits</button>
                        <button onclick="switchHistoryTab('withdraw')" class="flex-1 py-3 text-sm font-medium text-center border-b-2 border-transparent text-textGray">Withdrawals</button>
                        <button onclick="switchHistoryTab('transfer')" class="flex-1 py-3 text-sm font-medium text-center border-b-2 border-transparent text-textGray">Transfers</button>
                    </div>
                </div>
                <div id="history-content" class="p-4 space-y-2"></div>
            </div>

            <!-- Transfer View -->
            <div id="view-transfer" class="view-section hidden animate-fade-in">
                <div class="p-4 max-w-md mx-auto">
                    <h2 class="text-xl font-bold mb-6"><i class="fas fa-exchange-alt text-primary mr-2"></i>Internal Transfer</h2>
                    <div class="glass rounded-xl p-6 space-y-4">
                        <div>
                            <label class="text-textGray text-xs mb-2 block">From</label>
                            <select id="transfer-from" class="input-trade" onchange="updateTransferTo()">
                                <option value="spot">Spot Account</option>
                                <option value="futures">Futures Account</option>
                                <option value="margin">Margin Account</option>
                                <option value="nft">NFT Account</option>
                                <option value="invest">Invest Account</option>
                            </select>
                        </div>
                        <div class="flex justify-center">
                            <button onclick="swapTransferAccounts()" class="btn-animated w-10 h-10 rounded-full bg-surfaceLight flex items-center justify-center border border-border hover:border-primary"><i class="fas fa-exchange-alt text-primary"></i></button>
                        </div>
                        <div>
                            <label class="text-textGray text-xs mb-2 block">To</label>
                            <select id="transfer-to" class="input-trade">
                                <option value="futures">Futures Account</option>
                                <option value="margin">Margin Account</option>
                                <option value="spot">Spot Account</option>
                                <option value="nft">NFT Account</option>
                                <option value="invest">Invest Account</option>
                            </select>
                        </div>
                        <div>
                            <label class="text-textGray text-xs mb-2 block">Amount</label>
                            <input type="number" id="transfer-amount" class="input-trade" placeholder="0.00">
                            <p class="text-textGray text-xs mt-1">Available: <span id="transfer-available">0.00</span> USDT</p>
                        </div>
                        <button onclick="executeTransfer()" class="btn-animated btn-gold w-full py-3 rounded-lg mt-4">Transfer Now</button>
                    </div>
                </div>
            </div>

            <!-- KYC View -->
            <div id="view-kyc" class="view-section hidden animate-fade-in">
                <div class="p-4 max-w-md mx-auto">
                    <div class="flex items-center gap-3 mb-6">
                        <button onclick="navigateTo('profile')" class="btn-animated w-10 h-10 rounded-lg bg-surfaceLight flex items-center justify-center hover:bg-surfaceLighter"><i class="fas fa-arrow-left"></i></button>
                        <h2 class="text-xl font-bold">Identity Verification</h2>
                    </div>
                    <div id="kyc-form-container" class="glass rounded-xl p-6 space-y-4">
                        <div class="text-center mb-6">
                            <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-3"><i class="fas fa-shield-alt text-2xl text-primary"></i></div>
                            <h3 class="font-bold text-lg">KYC Verification</h3>
                            <p class="text-textGray text-sm">Complete your identity verification to unlock all features</p>
                        </div>
                        <div><label class="text-textGray text-xs mb-2 block">Full Name <span class="text-danger">*</span></label><input type="text" id="kyc-name" class="input-trade" placeholder="Enter your full name"></div>
                        <div><label class="text-textGray text-xs mb-2 block">Phone Number <span class="text-danger">*</span></label><input type="tel" id="kyc-phone" class="input-trade" placeholder="+91 00000 00000"></div>
                        <div><label class="text-textGray text-xs mb-2 block">Email <span class="text-danger">*</span></label><input type="email" id="kyc-email" class="input-trade" placeholder="Enter your email"></div>
                        <div>
                            <label class="text-textGray text-xs mb-2 block">Document Type <span class="text-danger">*</span></label>
                            <select id="kyc-document-type" class="input-trade">
                                <option value="">Select Document</option>
                                <option value="aadhar">Aadhaar Card</option>
                                <option value="pan">PAN Card</option>
                                <option value="passport">Passport</option>
                                <option value="driving">Driving License</option>
                            </select>
                        </div>
                        <div><label class="text-textGray text-xs mb-2 block">Document Number <span class="text-danger">*</span></label><input type="text" id="kyc-document-number" class="input-trade" placeholder="Enter document number"></div>
                        <div>
                            <label class="text-textGray text-xs mb-2 block">Your Photo <span class="text-danger">*</span></label>
                            <div class="border-2 border-dashed border-border rounded-lg p-4 text-center cursor-pointer hover:border-primary transition-colors relative" onclick="document.getElementById('kyc-photo').click()">
                                <img id="kyc-photo-preview" class="w-24 h-24 rounded-lg object-cover mx-auto mb-2 hidden">
                                <i id="kyc-photo-icon" class="fas fa-camera text-3xl text-textGray mb-2"></i>
                                <p id="kyc-photo-text" class="text-textGray text-xs">Click to upload photo</p>
                                <input type="file" id="kyc-photo" class="hidden" accept="image/*" onchange="previewKYCPhoto(this)">
                            </div>
                        </div>
                        <div>
                            <label class="text-textGray text-xs mb-2 block">Document Image <span class="text-danger">*</span></label>
                            <div class="border-2 border-dashed border-border rounded-lg p-4 text-center cursor-pointer hover:border-primary transition-colors relative" onclick="document.getElementById('kyc-document').click()">
                                <img id="kyc-document-preview" class="w-32 h-20 rounded-lg object-cover mx-auto mb-2 hidden">
                                <i id="kyc-document-icon" class="fas fa-id-card text-3xl text-textGray mb-2"></i>
                                <p id="kyc-document-text" class="text-textGray text-xs">Click to upload document</p>
                                <input type="file" id="kyc-document" class="hidden" accept="image/*" onchange="previewKYCDocument(this)">
                            </div>
                        </div>
                        <button onclick="submitKYC()" id="kyc-submit-btn" class="btn-animated btn-gold w-full py-3 rounded-lg mt-4">Submit for Verification</button>
                    </div>
                    <div id="kyc-status-container" class="hidden glass rounded-xl p-6 text-center">
                        <div class="w-20 h-20 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4"><i id="kyc-status-icon" class="fas fa-check-circle text-4xl text-primary"></i></div>
                        <h3 id="kyc-status-title" class="font-bold text-xl mb-2">Verification Submitted</h3>
                        <p id="kyc-status-desc" class="text-textGray mb-4">Your documents are under review. We will notify you once verified.</p>
                        <div id="kyc-reject-reason" class="hidden bg-danger/10 border border-danger/30 rounded-lg p-3 mb-4 text-left">
                            <p class="text-danger text-sm font-bold mb-1">Rejection Reason:</p>
                            <p id="kyc-reject-msg" class="text-textGray text-sm"></p>
                        </div>
                        <div class="bg-surface rounded-lg p-4 text-left space-y-2 mb-4">
                            <p class="text-sm"><span class="text-textGray">Status:</span> <span id="kyc-status-text" class="text-primary font-bold">Pending Review</span></p>
                            <p class="text-sm"><span class="text-textGray">Submitted:</span> <span id="kyc-submit-date">-</span></p>
                            <p class="text-sm"><span class="text-textGray">Document:</span> <span id="kyc-doc-type-display">-</span></p>
                        </div>
                        <button id="kyc-resubmit-btn" onclick="resubmitKYC()" class="hidden w-full btn-gold text-black font-bold py-3 rounded-lg">Resubmit Documents</button>
                    </div>
                </div>
            </div>

            <!-- Report Issue View -->
            <div id="view-report" class="view-section hidden animate-fade-in">
                <div class="p-4 max-w-md mx-auto">
                    <div class="flex items-center gap-3 mb-6">
                        <button onclick="navigateTo('home')" class="btn-animated w-10 h-10 rounded-lg bg-surfaceLight flex items-center justify-center hover:bg-surfaceLighter"><i class="fas fa-arrow-left"></i></button>
                        <h2 class="text-xl font-bold">Report an Issue</h2>
                    </div>
                    <div class="glass rounded-xl p-6 space-y-4">
                        <div>
                            <label class="text-textGray text-xs mb-2 block">Issue Type <span class="text-danger">*</span></label>
                            <select id="report-type" class="input-trade">
                                <option value="deposit">Deposit Issue</option>
                                <option value="withdrawal">Withdrawal Issue</option>
                                <option value="trading">Trading Problem</option>
                                <option value="nft">NFT Issue</option>
                                <option value="investment">Investment Issue</option>
                                <option value="account">Account Problem</option>
                                <option value="other">Other</option>
                            </select>
                        </div>
                        <div><label class="text-textGray text-xs mb-2 block">Subject <span class="text-danger">*</span></label><input type="text" id="report-subject" class="input-trade" placeholder="Brief description of issue"></div>
                        <div><label class="text-textGray text-xs mb-2 block">Detailed Description <span class="text-danger">*</span></label><textarea id="report-description" rows="4" class="input-trade" placeholder="Please describe your issue in detail..."></textarea></div>
                        <div>
                            <label class="text-textGray text-xs mb-2 block">Attachment</label>
                            <div class="file-upload-area" onclick="document.getElementById('report-file').click()">
                                <input type="file" id="report-file" class="hidden" accept="image/*,video/*" onchange="handleReportFile(this)">
                                <i class="fas fa-cloud-upload-alt text-3xl text-textGray mb-2"></i>
                                <p class="text-textGray text-sm">Click to upload Screenshot or Video</p>
                                <p id="report-file-name" class="text-primary text-xs mt-2 hidden"></p>
                            </div>
                        </div>
                        <button onclick="submitReport()" id="report-submit-btn" class="btn-animated btn-gold w-full py-3 rounded-lg mt-4">Submit Report</button>
                        <div class="mt-4 p-4 bg-surface rounded-lg"><p class="text-textGray text-xs text-center">Our team will review your report and contact you within 24 hours</p></div>
                    </div>
                    <div class="mt-6">
                        <h3 class="font-bold mb-4">Your Previous Reports</h3>
                        <div id="previous-reports" class="space-y-3"><p class="text-textGray text-center py-4">No reports submitted</p></div>
                    </div>
                </div>
            </div>
        </main>

        <!-- Mobile Bottom Navigation - 7 Tabs -->
        <nav class="mobile-nav mobile-only">
            <button onclick="navigateTo('home')" class="mobile-nav-item active" data-view="home"><i class="fas fa-home text-lg"></i><span>Home</span></button>
            <button onclick="navigateTo('market')" class="mobile-nav-item" data-view="market"><i class="fas fa-chart-bar text-lg"></i><span>Market</span></button>
            <button onclick="navigateTo('trade')" class="mobile-nav-item" data-view="trade"><i class="fas fa-exchange-alt text-lg"></i><span>Trade</span></button>
            <button onclick="navigateTo('invest')" class="mobile-nav-item" data-view="invest"><i class="fas fa-chart-pie text-lg"></i><span>Invest</span></button>
            <button onclick="navigateTo('nft')" class="mobile-nav-item" data-view="nft"><i class="fas fa-image text-lg"></i><span>NFT</span></button>
            <button onclick="navigateTo('wallet')" class="mobile-nav-item" data-view="wallet"><i class="fas fa-wallet text-lg"></i><span>Wallet</span></button>
            <button onclick="navigateTo('profile')" class="mobile-nav-item" data-view="profile"><i class="fas fa-user text-lg"></i><span>Profile</span></button>
        </nav>
    </div>

    <!-- Modals -->
    <div id="pay-modal" class="modal-overlay">
        <div class="modal-box">
            <div class="modal-header">
                <h3 class="text-lg font-bold text-primary"><i class="fas fa-arrow-down mr-2"></i>Deposit Funds</h3>
                <button onclick="closePay()" class="w-8 h-8 rounded-lg bg-surfaceLight flex items-center justify-center"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-body">
                <div class="flex bg-surface rounded-lg p-1 mb-4">
                    <button onclick="switchPaymentType('inr')" id="tab-inr" class="flex-1 py-2 rounded-lg text-sm font-bold btn-gold">INR (UPI)</button>
                    <button onclick="switchPaymentType('usdt')" id="tab-usdt" class="flex-1 py-2 rounded-lg text-sm font-bold text-textGray">USDT (Crypto)</button>
                </div>
                <div id="inr-section">
                    <div class="mb-4 text-left">
                        <label class="text-textGray text-xs mb-1 block">Enter Amount (INR)</label>
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 transform -translate-y-1/2 text-primary font-bold">₹</span>
                            <input type="number" id="deposit-amount" class="input-trade" style="text-align: left; padding-left: 30px;" placeholder="Min ₹500" oninput="updateDepositLinks()">
                        </div>
                        <p class="text-textGray text-xs mt-1">Min: ₹500 | Max: ₹5,00,000</p>
                    </div>
                    <div class="bg-surface p-3 rounded-lg mb-4 text-left">
                        <p class="text-textGray text-xs mb-2">Quick Select:</p>
                        <div class="grid grid-cols-4 gap-2">
                            <button onclick="setDepositAmount(500)" class="bg-surfaceLight hover:bg-primary hover:text-black text-xs py-2 rounded transition-colors">₹500</button>
                            <button onclick="setDepositAmount(1000)" class="bg-surfaceLight hover:bg-primary hover:text-black text-xs py-2 rounded transition-colors">₹1K</button>
                            <button onclick="setDepositAmount(5000)" class="bg-surfaceLight hover:bg-primary hover:text-black text-xs py-2 rounded transition-colors">₹5K</button>
                            <button onclick="setDepositAmount(10000)" class="bg-surfaceLight hover:bg-primary hover:text-black text-xs py-2 rounded transition-colors">₹10K</button>
                        </div>
                    </div>
                    <p id="p-amt" class="text-primary font-bold mb-4 text-lg"></p>
                    <div class="space-y-2 mb-4">
                        <button onclick="handlePaymentClick('gpay')" class="w-full p-3 bg-surfaceLight rounded-lg flex items-center gap-3 hover:bg-surfaceLighter transition-colors"><img src="https://img.icons8.com/color/48/google-pay.png" class="w-8 h-8"><span class="font-semibold">Google Pay</span></button>
                        <button onclick="handlePaymentClick('ppay')" class="w-full p-3 bg-surfaceLight rounded-lg flex items-center gap-3 hover:bg-surfaceLighter transition-colors"><img src="https://img.icons8.com/color/48/phone-pe.png" class="w-8 h-8"><span class="font-semibold">PhonePe</span></button>
                        <button onclick="handlePaymentClick('paytm')" class="w-full p-3 bg-surfaceLight rounded-lg flex items-center gap-3 hover:bg-surfaceLighter transition-colors"><img src="https://img.icons8.com/color/48/paytm.png" class="w-8 h-8"><span class="font-semibold">Paytm</span></button>
                    </div>
                    <div class="border-t border-border my-4 pt-4">
                        <p class="text-textGray text-xs mb-2">After Payment, Submit Details:</p>
                        <input type="text" id="txid" class="input-trade mb-3" placeholder="Enter UTR / Transaction ID">
                        <label class="text-textGray text-xs mb-2 block">Upload Payment Screenshot <span class="text-danger">*</span></label>
                        <div class="file-upload-area mb-3" onclick="document.getElementById('inr-screenshot').click()">
                            <input type="file" id="inr-screenshot" class="hidden" accept="image/*" onchange="handleINRScreenshot(this)">
                            <i class="fas fa-image text-2xl text-textGray mb-1"></i>
                            <p id="inr-file-text" class="text-textGray text-xs">Click to upload screenshot</p>
                        </div>
                    </div>
                </div>
                <div id="usdt-section" class="hidden">
                    <div class="mb-4 text-left">
                        <label class="text-textGray text-xs mb-1 block">USDT Amount (BEP20)</label>
                        <input type="number" id="usdt-amount" class="input-trade" placeholder="Min 10 USDT" oninput="calculateUSDT()">
                        <p class="text-textGray text-xs mt-1" id="usdt-inr">≈ ₹0</p>
                    </div>
                    <div class="bg-surface p-3 rounded-lg mb-4 text-left">
                        <p class="text-textGray text-xs mb-2">Network: BEP20 (BSC)</p>
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-sm text-textGray">Deposit Address:</span>
                            <button onclick="copyAddress('usdt-address')" class="px-3 py-1 btn-gold text-xs rounded font-bold">Copy</button>
                        </div>
                        <div id="usdt-address" class="text-xs text-textGray break-all mb-3 font-mono bg-black p-2 rounded">0x...</div>
                        <p class="text-xs text-danger">* Only send USDT (BEP20) to this address</p>
                    </div>
                    <div class="border-t border-border my-4 pt-4">
                        <p class="text-textGray text-xs mb-2">After Transfer, Submit Details:</p>
                        <input type="text" id="usdt-txid" class="input-trade mb-3" placeholder="Enter Transaction Hash / TxID">
                        <label class="text-textGray text-xs mb-2 block">Upload Transaction Screenshot <span class="text-danger">*</span></label>
                        <div class="file-upload-area mb-3" onclick="document.getElementById('usdt-screenshot').click()">
                            <input type="file" id="usdt-screenshot" class="hidden" accept="image/*" onchange="handleUSDTScreenshot(this)">
                            <i class="fas fa-image text-2xl text-textGray mb-1"></i>
                            <p id="usdt-file-text" class="text-textGray text-xs">Click to upload screenshot</p>
                        </div>
                    </div>
                </div>
                <button onclick="verifyLogic()" id="v-btn" class="btn-animated btn-gold w-full py-3 rounded-lg" disabled><span id="v-btn-text">VERIFY PAYMENT</span><i id="v-btn-icon" class="fas fa-check ml-2"></i></button>
            </div>
        </div>
    </div>

    <div id="withdraw-modal" class="modal-overlay">
        <div class="modal-box" style="border-top: 3px solid #ff4757;">
            <div class="modal-header">
                <h3 class="text-lg font-bold text-danger"><i class="fas fa-arrow-up mr-2"></i>Withdraw Funds</h3>
                <button onclick="closeWithdrawModal()" class="w-8 h-8 rounded-lg bg-surfaceLight flex items-center justify-center"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-body space-y-4">
                <div class="bg-surfaceLight rounded-lg p-4 border border-border">
                    <p class="text-textGray text-xs mb-1">Available Balance</p>
                    <p id="withdraw-available" class="text-2xl font-bold font-mono text-primary">₹0.00</p>
                </div>
                <div>
                    <label class="text-textGray text-xs mb-2 block">Select Account <span class="text-danger">*</span></label>
                    <select id="withdraw-account" class="input-trade" onchange="updateWithdrawAvailable()">
                        <option value="spot">Spot Account</option>
                        <option value="futures">Futures Account</option>
                        <option value="margin">Margin Account</option>
                        <option value="invest">Invest Account</option>
                        <option value="nft">NFT Account</option>
                    </select>
                </div>
                <div>
                    <label class="text-textGray text-xs mb-2 block">Amount (₹) <span class="text-danger">*</span></label>
                    <input type="number" id="withdraw-amount" class="input-trade text-lg font-bold" placeholder="Min ₹500">
                    <p class="text-textGray text-xs mt-1">Min: ₹500 | Max: <span id="max-withdraw">0</span></p>
                </div>
                <div>
                    <label class="text-textGray text-xs mb-2 block">UPI ID <span class="text-danger">*</span></label>
                    <input type="text" id="withdraw-upi" class="input-trade" placeholder="name@upi">
                </div>
                <div>
                    <label class="text-textGray text-xs mb-2 block">Account Holder Name</label>
                    <input type="text" id="withdraw-name" class="input-trade" placeholder="Enter account holder name">
                </div>
                <div class="bg-danger/10 border border-danger/30 rounded-lg p-3">
                    <p class="text-danger text-xs"><i class="fas fa-info-circle mr-1"></i> Withdrawal will be processed within 24 hours after admin approval.</p>
                </div>
                <button onclick="submitWithdraw()" id="withdraw-submit-btn" class="btn-animated w-full bg-danger text-white font-bold py-3 rounded-lg flex items-center justify-center gap-2 hover:bg-danger/90"><span>Request Withdrawal</span><i class="fas fa-paper-plane"></i></button>
            </div>
        </div>
    </div>

    <div id="invest-modal" class="modal-overlay">
        <div class="modal-box">
            <div class="modal-header">
                <h3 class="text-lg font-bold text-primary"><i class="fas fa-chart-pie mr-2"></i>Invest Now</h3>
                <button onclick="closeInvestModal()" class="w-8 h-8 rounded-lg bg-surfaceLight flex items-center justify-center"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-body">
                <div id="invest-details" class="text-left mb-4"></div>
                <div class="space-y-3 text-left">
                    <div>
                        <label class="text-textGray text-xs mb-1 block">Investment Amount (₹)</label>
                        <input type="number" id="invest-amount" class="input-trade" placeholder="Enter amount">
                        <p class="text-textGray text-xs mt-1" id="invest-min">Min: ₹1,000</p>
                    </div>
                    <div>
                        <label class="text-textGray text-xs mb-1 block">Duration (Days)</label>
                        <select id="invest-duration" class="input-trade">
                            <option value="30">30 Days</option>
                            <option value="60">60 Days</option>
                            <option value="90">90 Days</option>
                            <option value="180">180 Days</option>
                        </select>
                    </div>
                    <div class="bg-surface p-3 rounded-lg">
                        <p class="text-textGray text-xs">Expected Returns</p>
                        <p id="invest-returns" class="text-primary font-bold text-lg">₹0.00</p>
                    </div>
                </div>
                <button onclick="submitInvestment()" class="btn-animated btn-gold w-full py-3 rounded-lg mt-4">CONFIRM INVESTMENT</button>
            </div>
        </div>
    </div>

    <div id="pair-selector-modal" class="modal-overlay">
        <div class="modal-box" style="max-height: 80vh;">
            <div class="modal-header">
                <h3 class="text-lg font-bold">Select Trading Pair</h3>
                <button onclick="closePairSelector()" class="w-8 h-8 rounded-lg bg-surfaceLight flex items-center justify-center"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-body">
                <input type="text" id="pair-search" class="input-trade mb-3" placeholder="Search pair..." oninput="filterPairs()">
                <div class="flex gap-2 mb-3 overflow-x-auto no-scrollbar">
                    <button class="px-3 py-1 rounded-full bg-primary text-black text-xs">USDT-M</button>
                    <button class="px-3 py-1 rounded-full bg-surfaceLight text-textGray text-xs">USDC-M</button>
                    <button class="px-3 py-1 rounded-full bg-surfaceLight text-textGray text-xs">Coin-M</button>
                </div>
                <div id="pair-list" class="space-y-1 max-h-64 overflow-y-auto"></div>
            </div>
        </div>
    </div>

    <div id="leverage-modal" class="modal-overlay">
        <div class="modal-box">
            <div class="modal-header">
                <h3 class="text-lg font-bold">Adjust Leverage</h3>
                <button onclick="closeLeverageModal()" class="w-8 h-8 rounded-lg bg-surfaceLight flex items-center justify-center"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-body">
                <div class="flex items-center justify-between mb-4">
                    <button onclick="adjustLeverage(-1)" class="w-10 h-10 rounded-lg bg-surfaceLight flex items-center justify-center"><i class="fas fa-minus"></i></button>
                    <span id="leverage-modal-value" class="text-3xl font-bold text-primary">10x</span>
                    <button onclick="adjustLeverage(1)" class="w-10 h-10 rounded-lg bg-surfaceLight flex items-center justify-center"><i class="fas fa-plus"></i></button>
                </div>
                <input type="range" min="1" max="125" value="10" class="leverage-slider mb-4" id="leverage-range" oninput="updateLeverageFromRange(this.value)">
                <div class="flex justify-between text-xs text-textGray mb-4"><span>1x</span><span>25x</span><span>50x</span><span>75x</span><span>100x</span><span>125x</span></div>
                <div class="bg-surface p-3 rounded-lg mb-4">
                    <p class="text-textGray text-xs">Max. open after adjusting leverage</p>
                    <p class="text-white font-mono">3,000,000 USDT</p>
                </div>
                <p class="text-danger text-xs mb-4"><i class="fas fa-exclamation-triangle mr-1"></i> Trading with leverage greater than 10x can easily lead to liquidation.</p>
                <button onclick="confirmLeverage()" class="btn-animated btn-gold w-full py-3 rounded-lg">Confirm</button>
            </div>
        </div>
    </div>

    <div id="margin-mode-modal" class="modal-overlay">
        <div class="modal-box">
            <div class="modal-header">
                <h3 class="text-lg font-bold">Margin Mode</h3>
                <button onclick="closeMarginModeModal()" class="w-8 h-8 rounded-lg bg-surfaceLight flex items-center justify-center"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-body">
                <p class="text-textGray text-xs mb-4">This margin mode adjustment will only affect the selected futures trading pair.</p>
                <div class="space-y-3">
                    <label class="flex items-start gap-3 p-4 bg-surface rounded-lg cursor-pointer border-2 border-primary">
                        <input type="radio" name="margin-mode" value="cross" checked class="mt-1 accent-primary">
                        <div><p class="font-bold">Cross</p><p class="text-textGray text-xs mt-1">All positions under the same margin asset share the same margin balance.</p></div>
                    </label>
                    <label class="flex items-start gap-3 p-4 bg-surface rounded-lg cursor-pointer border-2 border-transparent hover:border-border">
                        <input type="radio" name="margin-mode" value="isolated" class="mt-1 accent-primary">
                        <div><p class="font-bold">Isolated</p><p class="text-textGray text-xs mt-1">Maximum loss is limited to the position's margin.</p></div>
                    </label>
                </div>
                <button onclick="confirmMarginMode()" class="btn-animated btn-gold w-full py-3 rounded-lg mt-4">Confirm</button>
            </div>
        </div>
    </div>

    <div id="edit-profile-modal" class="modal-overlay">
        <div class="modal-box">
            <div class="modal-header">
                <h3 class="text-lg font-bold">Edit Profile</h3>
                <button onclick="closeEditProfile()" class="w-8 h-8 rounded-lg bg-surfaceLight flex items-center justify-center"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-body space-y-4">
                <div><label class="text-textGray text-xs mb-2 block">Full Name</label><input type="text" id="edit-name" class="input-trade" placeholder="Enter your name"></div>
                <div><label class="text-textGray text-xs mb-2 block">Phone Number</label><input type="tel" id="edit-phone" class="input-trade" placeholder="+91 00000 00000"></div>
                <div><label class="text-textGray text-xs mb-2 block">Email</label><input type="email" id="edit-email" class="input-trade" placeholder="Enter your email" readonly><p class="text-textGray text-xs mt-1">Email cannot be changed</p></div>
                <button onclick="saveProfile()" class="btn-animated btn-gold w-full py-3 rounded-lg mt-4">Save Changes</button>
            </div>
        </div>
    </div>

    <div id="logout-dialog" class="dialog-overlay">
        <div class="dialog-box">
            <i class="fas fa-sign-out-alt text-danger text-3xl mb-4"></i>
            <h3 class="font-bold text-lg mb-2">Confirm Logout</h3>
            <p class="text-textGray text-sm mb-6">Are you sure you want to logout?</p>
            <div class="flex gap-3">
                <button onclick="hideLogoutDialog()" class="flex-1 py-2 bg-surfaceLight rounded-lg text-sm font-semibold">Cancel</button>
                <button onclick="logout()" class="flex-1 py-2 bg-danger text-white rounded-lg text-sm font-semibold">Logout</button>
            </div>
        </div>
    </div>

    <div id="toast" class="toast"></div>

    <script>
        // ==========================================
        // 🔥 FIREBASE CONFIGURATION
        // ==========================================
        const firebaseConfig = {
            apiKey: "AIzaSyAozV8jcau0GuIKBPCMFAbChm75O9VE1Rs",
            authDomain: "treding-store-2.firebaseapp.com",
            databaseURL: "https://treding-store-2-default-rtdb.firebaseio.com",
            projectId: "treding-store-2",
            storageBucket: "treding-store-2.firebasestorage.app",
            messagingSenderId: "2938541914",
            appId: "1:2938541914:web:7fe53d76a34ec044c90563",
            measurementId: "G-9YWCKFZKB1"
        };
        
        firebase.initializeApp(firebaseConfig);
        const auth = firebase.auth();
        const db = firebase.firestore();
        const storage = firebase.storage();

        // ==========================================
        // 🎨 STATE MANAGEMENT
        // ==========================================
        const state = {
            user: null, 
            userData: null, 
            adminConfig: {}, 
            marketData: [],
            currentView: 'home', 
            tradeMode: 'futures',
            spotSide: 'buy',
            selectedPair: 'BTCUSDT',
            leverage: 10,
            marginMode: 'cross',
            orderType: 'limit',
            tradingViewWidget: null, 
            investPlans: [], 
            allNFTs: [],
            notifications: [], 
            unreadCount: 0, 
            paymentType: 'inr',
            tempFiles: { inr: null, usdt: null },
            forgotEmail: null,
            forgotOTP: null,
            navigationStack: ['home'],
            currentPrice: 67982.03
        };

        // ==========================================
        // 🚀 INITIALIZATION & AUTH
        // ==========================================
        auth.onAuthStateChanged(user => {
            if (user) { 
                state.user = user; 
                initializeApp(); 
            } else { 
                showAuthScreen(); 
            }
        });

        function showAuthScreen() {
            document.getElementById('loader').classList.add('hidden');
            document.getElementById('auth-screen').classList.remove('hidden');
            document.getElementById('app-container').classList.add('hidden');
        }

        function showApp() {
            document.getElementById('loader').classList.add('hidden');
            document.getElementById('auth-screen').classList.add('hidden');
            document.getElementById('app-container').classList.remove('hidden');
        }

        async function initializeApp() {
            // Real-time listeners
            db.collection('investmentPlans').onSnapshot(snapshot => {
                state.investPlans = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
                if (state.currentView === 'invest') renderInvestingPlans();
            });

            db.collection('nfts').onSnapshot(snapshot => {
                state.allNFTs = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
                if (state.currentView === 'nft') renderNFTs();
            });

            db.collection('admin').doc('config').onSnapshot(doc => {
                if (doc.exists) { 
                    state.adminConfig = doc.data(); 
                    updateAdminConfig(); 
                }
            });

            // User data with auto-create
            db.collection('users').doc(state.user.uid).onSnapshot(async doc => {
                if (doc.exists) { 
                    state.userData = doc.data(); 
                    updateUI(); 
                } else {
                    // Auto-create user document if not exists
                    await createUserDocument();
                }
            });

            loadNotifications();
            loadUserNFTs();
            loadUserInvestments();
            
            await loadMarketData();
            setInterval(loadMarketData, 10000);
            
            showApp();
            updateOrderBook();
        }

        async function createUserDocument() {
            const userDoc = {
                uid: state.user.uid,
                name: state.user.displayName || 'User',
                email: state.user.email || '',
                phone: '',
                spotBalance: 0,
                futuresBalance: 0,
                marginBalance: 0,
                investBalance: 0,
                nftBalance: 0,
                kycStatus: 'unverified',
                createdAt: firebase.firestore.FieldValue.serverTimestamp(),
                isActive: true
            };
            await db.collection('users').doc(state.user.uid).set(userDoc);
            state.userData = userDoc;
        }

        // ==========================================
        // 🔐 AUTHENTICATION FUNCTIONS
        // ==========================================
        function switchAuthTab(mode) {
            document.querySelectorAll('.auth-tab').forEach(tab => tab.classList.remove('active'));
            document.getElementById(`auth-tab-${mode}`).classList.add('active');
            
            document.getElementById('login-form').classList.add('hidden');
            document.getElementById('register-form').classList.add('hidden');
            document.getElementById('forgot-form').classList.add('hidden');
            
            if (mode === 'login') {
                document.getElementById('login-form').classList.remove('hidden');
                document.getElementById('auth-subtitle').textContent = 'Login to continue trading';
            } else if (mode === 'register') {
                document.getElementById('register-form').classList.remove('hidden');
                document.getElementById('auth-subtitle').textContent = 'Create a new account';
            } else {
                document.getElementById('forgot-form').classList.remove('hidden');
                document.getElementById('auth-subtitle').textContent = 'Reset your password';
                resetForgotSteps();
            }
        }

        function togglePassword(inputId) {
            const input = document.getElementById(inputId);
            input.type = input.type === 'password' ? 'text' : 'password';
        }

        async function handleEmailLogin() {
            const email = document.getElementById('login-email').value.trim();
            const password = document.getElementById('login-password').value;
            
            if (!email || !password) { 
                showToast('Please enter email and password', 'error'); 
                return; 
            }
            
            try { 
                await auth.signInWithEmailAndPassword(email, password); 
                showToast('Login successful!');
            } catch (error) { 
                showToast(error.message, 'error'); 
            }
        }

        async function handleRegister() {
            const name = document.getElementById('reg-name').value.trim();
            const phone = document.getElementById('reg-phone').value.trim();
            const email = document.getElementById('reg-email').value.trim();
            const password = document.getElementById('reg-password').value;
            const confirmPassword = document.getElementById('reg-confirm-password').value;
            
            if (!name || !phone || !email || !password) { 
                showToast('Please fill all fields', 'error'); 
                return; 
            }
            if (password !== confirmPassword) { 
                showToast('Passwords do not match', 'error'); 
                return; 
            }
            if (password.length < 6) { 
                showToast('Password must be at least 6 characters', 'error'); 
                return; 
            }
            
            try {
                const cred = await auth.createUserWithEmailAndPassword(email, password);
                await cred.user.updateProfile({ displayName: name });
                
                await db.collection('users').doc(cred.user.uid).set({
                    uid: cred.user.uid, name, phone, email,
                    spotBalance: 0, futuresBalance: 0, marginBalance: 0, investBalance: 0, nftBalance: 0,
                    kycStatus: 'unverified',
                    createdAt: firebase.firestore.FieldValue.serverTimestamp(),
                    isActive: true
                });
                showToast('Account created successfully!');
            } catch (error) { 
                showToast(error.message, 'error'); 
            }
        }

        // ==========================================
        // 🔑 FORGOT PASSWORD WITH OTP
        // ==========================================
        function resetForgotSteps() {
            document.getElementById('forgot-step-1').classList.remove('hidden');
            document.getElementById('forgot-step-2').classList.add('hidden');
            document.getElementById('forgot-step-3').classList.add('hidden');
            document.getElementById('forgot-email').value = '';
            for (let i = 0; i < 6; i++) document.getElementById(`otp-${i}`).value = '';
            document.getElementById('new-password').value = '';
            document.getElementById('new-password-confirm').value = '';
        }

        async function sendForgotOTP() {
            const email = document.getElementById('forgot-email').value.trim();
            if (!email) {
                showToast('Please enter your email', 'error');
                return;
            }
            
            try {
                // Check if email exists
                const methods = await auth.fetchSignInMethodsForEmail(email);
                if (methods.length === 0) {
                    showToast('Email not registered', 'error');
                    return;
                }
                
                state.forgotEmail = email;
                // Generate random 6-digit OTP
                state.forgotOTP = Math.floor(100000 + Math.random() * 900000).toString();
                
                // In production, send OTP via email service
                // For demo, we'll show it in console and toast
                console.log('OTP for', email, ':', state.forgotOTP);
                showToast(`OTP sent to ${email} (Check console for demo)`, 'success');
                
                document.getElementById('forgot-step-1').classList.add('hidden');
                document.getElementById('forgot-step-2').classList.remove('hidden');
                document.getElementById('otp-0').focus();
            } catch (error) {
                showToast(error.message, 'error');
            }
        }

        function handleOTPInput(input, index) {
            if (input.value.length === 1 && index < 5) {
                document.getElementById(`otp-${index + 1}`).focus();
            }
        }

        async function resendOTP() {
            if (state.forgotEmail) {
                state.forgotOTP = Math.floor(100000 + Math.random() * 900000).toString();
                console.log('New OTP:', state.forgotOTP);
                showToast('OTP resent! Check console for demo', 'success');
            }
        }

        function verifyOTP() {
            let enteredOTP = '';
            for (let i = 0; i < 6; i++) {
                enteredOTP += document.getElementById(`otp-${i}`).value;
            }
            
            if (enteredOTP === state.forgotOTP) {
                showToast('OTP verified successfully!', 'success');
                document.getElementById('forgot-step-2').classList.add('hidden');
                document.getElementById('forgot-step-3').classList.remove('hidden');
            } else {
                showToast('Invalid OTP', 'error');
            }
        }

        async function updatePassword() {
            const newPassword = document.getElementById('new-password').value;
            const confirmPassword = document.getElementById('new-password-confirm').value;
            
            if (!newPassword || newPassword.length < 6) {
                showToast('Password must be at least 6 characters', 'error');
                return;
            }
            if (newPassword !== confirmPassword) {
                showToast('Passwords do not match', 'error');
                return;
            }
            
            try {
                // Re-authenticate and update password
                await auth.currentUser.updatePassword(newPassword);
                showToast('Password updated successfully!', 'success');
                switchAuthTab('login');
            } catch (error) {
                // If user not logged in, we need to sign in first
                try {
                    const userCredential = await auth.signInWithEmailAndPassword(state.forgotEmail, state.forgotOTP);
                    await userCredential.user.updatePassword(newPassword);
                    showToast('Password updated successfully!', 'success');
                    switchAuthTab('login');
                } catch (err) {
                    showToast('Please login with your old password first', 'error');
                }
            }
        }

        function confirmLogout() { 
            document.getElementById('logout-dialog').style.display = 'flex'; 
        }
        
        function hideLogoutDialog() { 
            document.getElementById('logout-dialog').style.display = 'none'; 
        }
        
        function logout() { 
            hideLogoutDialog(); 
            auth.signOut(); 
        }

        // ==========================================
        // 🎨 UI UPDATES
        // ==========================================
        function updateUI() {
            const data = state.userData;
            const spot = data.spotBalance || 0;
            const futures = data.futuresBalance || 0;
            const margin = data.marginBalance || 0;
            const invest = data.investBalance || 0;
            const nft = data.nftBalance || 0;
            const total = spot + futures + margin + invest + nft;

            document.getElementById('nft-value').textContent = formatCurrency(nft);
            document.getElementById('invest-value').textContent = formatCurrency(invest);
            document.getElementById('total-balance-display').textContent = formatCurrency(total);
            document.getElementById('menu-balance').textContent = formatCurrency(total);
            document.getElementById('wallet-total').textContent = formatCurrency(total);
            document.getElementById('spot-balance').textContent = formatCurrency(spot);
            document.getElementById('futures-balance').textContent = formatCurrency(futures);
            document.getElementById('margin-balance').textContent = formatCurrency(margin);
            document.getElementById('nft-balance-display').textContent = formatCurrency(nft);
            document.getElementById('invest-balance-display').textContent = formatCurrency(invest);
            
            document.getElementById('futures-available-balance').textContent = futures.toFixed(2) + ' USDT';
            document.getElementById('transfer-available').textContent = spot.toFixed(2);
            document.getElementById('spot-available-balance').textContent = spot.toFixed(2) + ' USDT';
            
            document.getElementById('menu-name').textContent = data.name || 'User';
            document.getElementById('profile-name').textContent = data.name || 'User';
            document.getElementById('profile-email').textContent = data.email || '';
            
            if (data.avatar) {
                document.getElementById('menu-avatar').src = data.avatar;
                document.getElementById('profile-avatar').src = data.avatar;
                document.getElementById('wallet-avatar').src = data.avatar;
            }

            document.getElementById('profile-total').textContent = '₹' + total.toFixed(2);
            document.getElementById('profile-crypto').textContent = '₹' + (spot + futures).toFixed(2);
            document.getElementById('profile-invest').textContent = '₹' + invest.toFixed(2);

            updateKYCProfileBadge(data.kycStatus);
        }

        function updateKYCProfileBadge(status) {
            const badge = document.getElementById('kyc-profile-badge');
            const badgeText = document.getElementById('kyc-badge-text');
            const statusBadge = document.getElementById('kyc-status-badge');
            
            if (status === 'verified') {
                badge.className = 'inline-flex items-center gap-2 mt-2 px-3 py-1 rounded-full bg-success/20 text-xs';
                badgeText.textContent = 'Verified';
                if (statusBadge) {
                    statusBadge.className = 'kyc-status-badge kyc-status-verified';
                    statusBadge.textContent = 'Verified';
                }
            } else if (status === 'pending') {
                badge.className = 'inline-flex items-center gap-2 mt-2 px-3 py-1 rounded-full bg-primary/20 text-xs';
                badgeText.textContent = 'Pending';
                if (statusBadge) {
                    statusBadge.className = 'kyc-status-badge kyc-status-pending';
                    statusBadge.textContent = 'Pending';
                }
            } else {
                badge.className = 'inline-flex items-center gap-2 mt-2 px-3 py-1 rounded-full bg-surfaceLight text-xs';
                badgeText.textContent = 'Unverified';
                if (statusBadge) {
                    statusBadge.className = 'kyc-status-badge kyc-status-pending';
                    statusBadge.textContent = 'Unverified';
                }
            }
        }

        function updateAdminConfig() {
            if (state.adminConfig.usdtAddress) {
                document.getElementById('usdt-address').textContent = state.adminConfig.usdtAddress;
            }
        }

        function formatCurrency(amount) {
            return '₹' + (amount || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        // ==========================================
        // 🧭 NAVIGATION
        // ==========================================
        function navigateTo(view) {
            document.querySelectorAll('.view-section').forEach(el => el.classList.add('hidden'));
            const viewEl = document.getElementById(`view-${view}`);
            if (viewEl) viewEl.classList.remove('hidden');
            
            document.querySelectorAll('.mobile-nav-item').forEach(el => { 
                el.classList.toggle('active', el.dataset.view === view); 
            });
            
            state.currentView = view;
            window.scrollTo(0, 0);
            
            if (view === 'trade') {
                setTimeout(() => initTradingView(), 100);
            } else if (view === 'invest') {
                renderInvestingPlans();
            } else if (view === 'nft') {
                renderNFTs();
            } else if (view === 'wallet') {
                loadWalletData();
            }
        }

        function openSideMenu() { 
            document.getElementById('side-menu').classList.add('open'); 
            document.getElementById('menu-overlay').classList.add('open'); 
        }
        
        function closeSideMenu() { 
            document.getElementById('side-menu').classList.remove('open'); 
            document.getElementById('menu-overlay').classList.remove('open'); 
        }

        function openNotifications() {
            document.getElementById('notification-panel').classList.remove('hidden');
            document.getElementById('notification-panel').classList.add('flex');
        }

        function closeNotifications() {
            document.getElementById('notification-panel').classList.add('hidden');
            document.getElementById('notification-panel').classList.remove('flex');
        }

        // ==========================================
        // 📊 MARKET FUNCTIONS
        // ==========================================
        async function loadMarketData() {
            try {
                const response = await fetch('https://api.coingecko.com/api/v3/coins/markets?vs_currency=usd&order=market_cap_desc&per_page=100&page=1&sparkline=false&price_change_percentage=24h');
                state.marketData = await response.json();
                renderMarketList();
                renderTrending();
            } catch (error) { 
                console.error('Market data load failed'); 
            }
        }

        function renderMarketList() {
            const container = document.getElementById('market-list');
            if (!container) return;
            const searchTerm = document.getElementById('market-search')?.value.toLowerCase() || '';
            
            let data = state.marketData;
            if (searchTerm) {
                data = data.filter(coin => 
                    coin.name.toLowerCase().includes(searchTerm) || 
                    coin.symbol.toLowerCase().includes(searchTerm)
                );
            }
            
            container.innerHTML = data.map(coin => `
                <div class="market-item" onclick="openTrading('${coin.symbol.toUpperCase()}')">
                    <div class="flex items-center gap-3 flex-1">
                        <img src="${coin.image}" class="w-8 h-8 rounded-full">
                        <div>
                            <p class="font-bold text-sm">${coin.symbol.toUpperCase()}</p>
                            <p class="text-textGray text-xs">${coin.name}</p>
                        </div>
                    </div>
                    <div class="w-24 text-right">
                        <p class="font-mono font-bold text-sm ${coin.price_change_percentage_24h >= 0 ? 'text-tradeGreen' : 'text-tradeRed'}">
                            $${coin.current_price.toLocaleString()}
                        </p>
                    </div>
                    <div class="w-20 text-right">
                        <span class="${coin.price_change_percentage_24h >= 0 ? 'text-tradeGreen' : 'text-tradeRed'} text-sm font-bold">
                            ${coin.price_change_percentage_24h >= 0 ? '+' : ''}${coin.price_change_percentage_24h?.toFixed(2) || 0}%
                        </span>
                    </div>
                </div>
            `).join('');
        }

        function renderTrending() {
            const container = document.getElementById('trending-list');
            if (!container) return;
            const trending = state.marketData.slice(0, 5);
            container.innerHTML = trending.map(coin => `
                <div class="glass rounded-lg p-3 flex items-center justify-between cursor-pointer" onclick="openTrading('${coin.symbol.toUpperCase()}')">
                    <div class="flex items-center gap-3">
                        <img src="${coin.image}" class="w-8 h-8 rounded-full">
                        <div>
                            <p class="font-bold text-sm">${coin.symbol.toUpperCase()}</p>
                            <p class="text-textGray text-xs">$${coin.current_price.toLocaleString()}</p>
                        </div>
                    </div>
                    <span class="${coin.price_change_percentage_24h >= 0 ? 'text-tradeGreen' : 'text-tradeRed'} text-sm font-bold">
                        ${coin.price_change_percentage_24h >= 0 ? '+' : ''}${coin.price_change_percentage_24h?.toFixed(2) || 0}%
                    </span>
                </div>
            `).join('');
        }

        function filterMarket(type) {
            document.querySelectorAll('.market-filter').forEach(btn => {
                btn.classList.remove('active', 'bg-primary', 'text-black');
                btn.classList.add('bg-surfaceLight', 'text-textGray');
            });
            event.target.classList.add('active', 'bg-primary', 'text-black');
            event.target.classList.remove('bg-surfaceLight', 'text-textGray');
            
            let data = [...state.marketData];
            if (type === 'gainers') data = data.filter(c => c.price_change_percentage_24h > 0).sort((a,b) => b.price_change_percentage_24h - a.price_change_percentage_24h);
            if (type === 'losers') data = data.filter(c => c.price_change_percentage_24h < 0).sort((a,b) => a.price_change_percentage_24h - b.price_change_percentage_24h);
            if (type === 'volume') data = data.sort((a,b) => b.total_volume - a.total_volume);
            
            const container = document.getElementById('market-list');
            container.innerHTML = data.map(coin => `
                <div class="market-item" onclick="openTrading('${coin.symbol.toUpperCase()}')">
                    <div class="flex items-center gap-3 flex-1">
                        <img src="${coin.image}" class="w-8 h-8 rounded-full">
                        <div>
                            <p class="font-bold text-sm">${coin.symbol.toUpperCase()}</p>
                            <p class="text-textGray text-xs">${coin.name}</p>
                        </div>
                    </div>
                    <div class="w-24 text-right">
                        <p class="font-mono font-bold text-sm ${coin.price_change_percentage_24h >= 0 ? 'text-tradeGreen' : 'text-tradeRed'}">
                            $${coin.current_price.toLocaleString()}
                        </p>
                    </div>
                    <div class="w-20 text-right">
                        <span class="${coin.price_change_percentage_24h >= 0 ? 'text-tradeGreen' : 'text-tradeRed'} text-sm font-bold">
                            ${coin.price_change_percentage_24h >= 0 ? '+' : ''}${coin.price_change_percentage_24h?.toFixed(2) || 0}%
                        </span>
                    </div>
                </div>
            `).join('');
        }

        function filterMarketSearch() { renderMarketList(); }

        function openTrading(symbol) {
            state.selectedPair = symbol + 'USDT';
            document.getElementById('futures-pair-name').textContent = state.selectedPair;
            navigateTo('trade');
        }

        // ==========================================
        // 📈 TRADING FUNCTIONS
        // ==========================================
        function switchTradeMode(mode) {
            state.tradeMode = mode;
            document.querySelectorAll('.trading-tab').forEach(tab => { 
                tab.classList.toggle('active', tab.dataset.mode === mode); 
            });
            document.querySelectorAll('.trade-mode-content').forEach(content => content.classList.add('hidden'));
            document.getElementById(`trade-${mode}`).classList.remove('hidden');
            
            if (mode === 'futures') {
                setTimeout(() => initTradingView(), 100);
            }
        }

        function initTradingView() {
            const pair = state.selectedPair;
            const symbol = `BINANCE:${pair}`;
            
            if (state.tradingViewWidget) {
                state.tradingViewWidget.setSymbol(symbol);
                return;
            }
            
            state.tradingViewWidget = new TradingView.widget({
                "width": "100%",
                "height": "300",
                "symbol": symbol,
                "interval": "1",
                "timezone": "Etc/UTC",
                "theme": "dark",
                "style": "1",
                "locale": "en",
                "toolbar_bg": "#f1f3f6",
                "enable_publishing": false,
                "allow_symbol_change": true,
                "hide_side_toolbar": false,
                "container_id": "tradingview-chart"
            });
        }

        function switchPositionTab(tab) {
            // Handle position tab switching
        }

        function switchTradeBottomTab(tab) {
            // Handle bottom tab switching
        }

        function toggleOrderTypeMenu() {
            document.getElementById('order-type-menu').classList.toggle('show');
        }

        function selectOrderType(type) {
            state.orderType = type;
            document.getElementById('order-type-label').textContent = type.charAt(0).toUpperCase() + type.slice(1);
            document.querySelectorAll('.order-type-item').forEach(item => item.classList.remove('active'));
            event.target.classList.add('active');
            document.getElementById('order-type-menu').classList.remove('show');
        }

        function setFuturesPercent(percent) {
            const balance = state.userData?.futuresBalance || 0;
            const price = parseFloat(document.getElementById('futures-price').value) || state.currentPrice;
            const quantity = (balance * percent / 100) / price;
            document.getElementById('futures-quantity').value = quantity.toFixed(6);
            updateOrderCosts();
        }

        function toggleTPSL() {
            const checked = document.getElementById('tp-sl-check').checked;
            document.getElementById('tp-sl-section').classList.toggle('hidden', !checked);
        }

        function updateOrderCosts() {
            const price = parseFloat(document.getElementById('futures-price').value) || state.currentPrice;
            const quantity = parseFloat(document.getElementById('futures-quantity').value) || 0;
            const cost = price * quantity;
            document.getElementById('long-cost').textContent = cost.toFixed(2) + ' USDT';
            document.getElementById('short-cost').textContent = cost.toFixed(2) + ' USDT';
        }

        function updateOrderBook() {
            const sellsContainer = document.getElementById('order-book-sells');
            const buysContainer = document.getElementById('order-book-buys');
            if (!sellsContainer || !buysContainer) return;
            
            const price = state.currentPrice;
            let sellsHTML = '';
            let buysHTML = '';
            
            for (let i = 5; i > 0; i--) {
                const sellPrice = price * (1 + i * 0.001);
                const amount = (Math.random() * 0.5).toFixed(4);
                const width = Math.random() * 80;
                sellsHTML += `
                    <div class="flex justify-between text-xs text-tradeRed relative py-0.5">
                        <div class="absolute right-0 top-0 bottom-0 bg-tradeRed opacity-10" style="width: ${width}%"></div>
                        <span>${sellPrice.toFixed(2)}</span>
                        <span>${amount}</span>
                    </div>
                `;
            }
            
            for (let i = 1; i <= 5; i++) {
                const buyPrice = price * (1 - i * 0.001);
                const amount = (Math.random() * 0.5).toFixed(4);
                const width = Math.random() * 80;
                buysHTML += `
                    <div class="flex justify-between text-xs text-tradeGreen relative py-0.5">
                        <div class="absolute right-0 top-0 bottom-0 bg-tradeGreen opacity-10" style="width: ${width}%"></div>
                        <span>${buyPrice.toFixed(2)}</span>
                        <span>${amount}</span>
                    </div>
                `;
            }
            
            sellsContainer.innerHTML = sellsHTML;
            buysContainer.innerHTML = buysHTML;
        }

        function openPairSelector() {
            document.getElementById('pair-selector-modal').classList.add('show');
            renderPairList();
        }

        function closePairSelector() {
            document.getElementById('pair-selector-modal').classList.remove('show');
        }

        function renderPairList() {
            const container = document.getElementById('pair-list');
            const pairs = ['BTCUSDT', 'ETHUSDT', 'SOLUSDT', 'XRPUSDT', 'DOGEUSDT', 'ADAUSDT', 'DOTUSDT', 'MATICUSDT'];
            container.innerHTML = pairs.map(pair => `
                <div class="flex items-center justify-between p-3 hover:bg-surfaceLight cursor-pointer rounded-lg" onclick="selectPair('${pair}')">
                    <div class="flex items-center gap-3">
                        <span class="font-bold">${pair}</span>
                        <span class="text-xs text-textGray">Perpetual</span>
                    </div>
                    <span class="text-tradeRed text-sm">-1.23%</span>
                </div>
            `).join('');
        }

        function selectPair(pair) {
            state.selectedPair = pair;
            document.getElementById('futures-pair-name').textContent = pair;
            closePairSelector();
            initTradingView();
        }

        function openLeverageModal() {
            document.getElementById('leverage-modal').classList.add('show');
            document.getElementById('leverage-modal-value').textContent = state.leverage + 'x';
            document.getElementById('leverage-range').value = state.leverage;
        }

        function closeLeverageModal() {
            document.getElementById('leverage-modal').classList.remove('show');
        }

        function adjustLeverage(delta) {
            let newLeverage = state.leverage + delta;
            if (newLeverage < 1) newLeverage = 1;
            if (newLeverage > 125) newLeverage = 125;
            state.leverage = newLeverage;
            document.getElementById('leverage-modal-value').textContent = newLeverage + 'x';
            document.getElementById('leverage-range').value = newLeverage;
        }

        function updateLeverageFromRange(value) {
            state.leverage = parseInt(value);
            document.getElementById('leverage-modal-value').textContent = value + 'x';
        }

        function confirmLeverage() {
            document.getElementById('leverage-display').textContent = state.leverage + 'x';
            closeLeverageModal();
        }

        function openMarginModeModal() {
            document.getElementById('margin-mode-modal').classList.add('show');
        }

        function closeMarginModeModal() {
            document.getElementById('margin-mode-modal').classList.remove('show');
        }

        function confirmMarginMode() {
            const mode = document.querySelector('input[name="margin-mode"]:checked').value;
            state.marginMode = mode;
            document.getElementById('margin-mode-display').textContent = mode.charAt(0).toUpperCase() + mode.slice(1);
            closeMarginModeModal();
        }

        function switchSpotSide(side) {
            state.spotSide = side;
            document.getElementById('spot-side-buy').className = side === 'buy' ? 'flex-1 py-2 rounded-lg bg-tradeGreen text-black font-bold' : 'flex-1 py-2 rounded-lg bg-surfaceLight text-white';
            document.getElementById('spot-side-sell').className = side === 'sell' ? 'flex-1 py-2 rounded-lg bg-tradeRed text-white font-bold' : 'flex-1 py-2 rounded-lg bg-surfaceLight text-white';
            document.getElementById('spot-action-btn').textContent = (side === 'buy' ? 'Buy ' : 'Sell ') + state.selectedPair.replace('USDT', '');
            document.getElementById('spot-action-btn').className = side === 'buy' ? 'btn-animated w-full bg-tradeGreen text-black font-bold py-3 rounded-lg' : 'btn-animated w-full bg-tradeRed text-white font-bold py-3 rounded-lg';
        }

        async function placeFuturesOrder(side) {
            const price = parseFloat(document.getElementById('futures-price').value) || state.currentPrice;
            const quantity = parseFloat(document.getElementById('futures-quantity').value);
            
            if (!quantity || quantity <= 0) {
                showToast('Please enter valid quantity', 'error');
                return;
            }
            
            showToast(`${side.toUpperCase()} order placed successfully!`);
        }

        async function placeSpotOrder() {
            const price = parseFloat(document.getElementById('spot-price-input').value);
            const amount = parseFloat(document.getElementById('spot-amount-input').value);
            
            if (!amount || amount <= 0) {
                showToast('Please enter valid amount', 'error');
                return;
            }
            
            showToast(`${state.spotSide.toUpperCase()} order placed successfully!`);
        }

        // ==========================================
        // 💰 DEPOSIT/WITHDRAW FUNCTIONS
        // ==========================================
        function openPay() {
            document.getElementById('pay-modal').classList.add('show');
        }

        function closePay() {
            document.getElementById('pay-modal').classList.remove('show');
        }

        function switchPaymentType(type) {
            state.paymentType = type;
            document.getElementById('tab-inr').className = type === 'inr' ? 'flex-1 py-2 rounded-lg text-sm font-bold btn-gold' : 'flex-1 py-2 rounded-lg text-sm font-bold text-textGray';
            document.getElementById('tab-usdt').className = type === 'usdt' ? 'flex-1 py-2 rounded-lg text-sm font-bold btn-gold' : 'flex-1 py-2 rounded-lg text-sm font-bold text-textGray';
            document.getElementById('inr-section').classList.toggle('hidden', type !== 'inr');
            document.getElementById('usdt-section').classList.toggle('hidden', type !== 'usdt');
        }

        function setDepositAmount(amount) {
            document.getElementById('deposit-amount').value = amount;
            updateDepositLinks();
        }

        function updateDepositLinks() {
            const amount = document.getElementById('deposit-amount').value;
            document.getElementById('p-amt').textContent = amount ? `₹${amount}` : '';
            document.getElementById('v-btn').disabled = !amount || amount < 500;
        }

        function handleINRScreenshot(input) {
            if (input.files && input.files[0]) {
                state.tempFiles.inr = input.files[0];
                document.getElementById('inr-file-text').textContent = input.files[0].name;
                document.getElementById('inr-file-text').classList.add('text-primary');
            }
        }

        function handleUSDTScreenshot(input) {
            if (input.files && input.files[0]) {
                state.tempFiles.usdt = input.files[0];
                document.getElementById('usdt-file-text').textContent = input.files[0].name;
                document.getElementById('usdt-file-text').classList.add('text-primary');
            }
        }

        function calculateUSDT() {
            const amount = parseFloat(document.getElementById('usdt-amount').value) || 0;
            const inrValue = amount * 85.5; // Approximate rate
            document.getElementById('usdt-inr').textContent = `≈ ₹${inrValue.toFixed(2)}`;
        }

        async function verifyLogic() {
            showToast('Payment verification submitted!', 'success');
            closePay();
        }

        function openWithdrawModal() {
            document.getElementById('withdraw-modal').classList.add('show');
            updateWithdrawAvailable();
        }

        function closeWithdrawModal() {
            document.getElementById('withdraw-modal').classList.remove('show');
        }

        function updateWithdrawAvailable() {
            const account = document.getElementById('withdraw-account').value;
            let balance = 0;
            if (state.userData) {
                balance = state.userData[account + 'Balance'] || 0;
            }
            document.getElementById('withdraw-available').textContent = '₹' + balance.toFixed(2);
            document.getElementById('max-withdraw').textContent = balance.toFixed(2);
        }

        async function submitWithdraw() {
            const amount = parseFloat(document.getElementById('withdraw-amount').value);
            const upi = document.getElementById('withdraw-upi').value.trim();
            
            if (!amount || amount < 500) {
                showToast('Minimum withdrawal amount is ₹500', 'error');
                return;
            }
            if (!upi) {
                showToast('Please enter UPI ID', 'error');
                return;
            }
            
            try {
                await db.collection('withdrawals').add({
                    uid: state.user.uid,
                    amount: amount,
                    upi: upi,
                    name: document.getElementById('withdraw-name').value,
                    account: document.getElementById('withdraw-account').value,
                    status: 'pending',
                    timestamp: firebase.firestore.FieldValue.serverTimestamp()
                });
                showToast('Withdrawal request submitted!', 'success');
                closeWithdrawModal();
            } catch (error) {
                showToast(error.message, 'error');
            }
        }

        // ==========================================
        // 💎 INVEST FUNCTIONS
        // ==========================================
        function renderInvestingPlans() {
            const container = document.getElementById('investing-list');
            const loading = document.getElementById('investing-loading');
            if (!container) return;
            
            loading.classList.add('hidden');
            container.classList.remove('hidden');
            
            const plans = state.investPlans.filter(p => p.risk === state.investRiskFilter);
            
            if (plans.length === 0) {
                container.innerHTML = '<p class="text-textGray text-center py-8">No investment plans available</p>';
                return;
            }
            
            container.innerHTML = plans.map(plan => `
                <div class="glass rounded-xl p-4">
                    <div class="flex items-center justify-between mb-3">
                        <h3 class="font-bold">${plan.name}</h3>
                        <span class="badge-gold">${plan.returnRate}%</span>
                    </div>
                    <p class="text-textGray text-sm mb-3">${plan.description}</p>
                    <div class="flex justify-between text-sm mb-3">
                        <span class="text-textGray">Min: ₹${plan.min}</span>
                        <span class="text-textGray">Max: ₹${plan.max}</span>
                    </div>
                    <button onclick="openInvestModal('${plan.id}')" class="btn-animated w-full btn-gold py-2 rounded-lg">Invest Now</button>
                </div>
            `).join('');
        }

        function filterInvestByRisk(risk) {
            state.investRiskFilter = risk;
            document.querySelectorAll('.risk-tab').forEach(tab => {
                tab.classList.remove('active', risk);
                if (tab.dataset.risk === risk) tab.classList.add('active', risk);
            });
            renderInvestingPlans();
        }

        function openInvestModal(planId) {
            const plan = state.investPlans.find(p => p.id === planId);
            if (!plan) return;
            state.selectedInvestPlan = plan;
            document.getElementById('invest-details').innerHTML = `
                <h3 class="font-bold text-lg">${plan.name}</h3>
                <p class="text-textGray text-sm">Return Rate: ${plan.returnRate}%</p>
            `;
            document.getElementById('invest-min').textContent = `Min: ₹${plan.min} | Max: ₹${plan.max}`;
            document.getElementById('invest-modal').classList.add('show');
        }

        function closeInvestModal() {
            document.getElementById('invest-modal').classList.remove('show');
        }

        async function submitInvestment() {
            const amount = parseFloat(document.getElementById('invest-amount').value);
            const plan = state.selectedInvestPlan;
            
            if (!amount || amount < plan.min || amount > plan.max) {
                showToast(`Amount must be between ₹${plan.min} and ₹${plan.max}`, 'error');
                return;
            }
            
            try {
                await db.collection('investments').add({
                    uid: state.user.uid,
                    planId: plan.id,
                    planName: plan.name,
                    amount: amount,
                    returnRate: plan.returnRate,
                    duration: parseInt(document.getElementById('invest-duration').value),
                    status: 'active',
                    timestamp: firebase.firestore.FieldValue.serverTimestamp()
                });
                
                // Deduct from spot balance
                await db.collection('users').doc(state.user.uid).update({
                    spotBalance: firebase.firestore.FieldValue.increment(-amount),
                    investBalance: firebase.firestore.FieldValue.increment(amount)
                });
                
                showToast('Investment successful!', 'success');
                closeInvestModal();
            } catch (error) {
                showToast(error.message, 'error');
            }
        }

        // ==========================================
        // 🖼️ NFT FUNCTIONS
        // ==========================================
        function renderNFTs() {
            const container = document.getElementById('nft-list');
            const loading = document.getElementById('nft-loading');
            if (!container) return;
            
            loading.classList.add('hidden');
            container.classList.remove('hidden');
            
            if (state.allNFTs.length === 0) {
                container.innerHTML = '<p class="text-textGray text-center py-8">No NFTs available</p>';
                return;
            }
            
            container.innerHTML = state.allNFTs.map(nft => `
                <div class="glass rounded-xl overflow-hidden">
                    <img src="${nft.image}" class="w-full h-32 object-cover">
                    <div class="p-3">
                        <h4 class="font-bold text-sm">${nft.name}</h4>
                        <p class="text-primary font-bold">₹${nft.price}</p>
                        <button onclick="buyNFT('${nft.id}')" class="btn-animated w-full btn-gold py-2 rounded-lg text-sm mt-2">Buy Now</button>
                    </div>
                </div>
            `).join('');
        }

        function switchNFTTab(tab) {
            document.querySelectorAll('.nft-tab').forEach(t => t.classList.remove('active'));
            document.querySelector(`[data-tab="${tab}"]`).classList.add('active');
            state.nftTab = tab;
            if (tab === 'sell') renderUserNFTs();
            else renderNFTs();
        }

        async function buyNFT(nftId) {
            const nft = state.allNFTs.find(n => n.id === nftId);
            if (!nft) return;
            
            if ((state.userData?.spotBalance || 0) < nft.price) {
                showToast('Insufficient balance', 'error');
                return;
            }
            
            try {
                await db.collection('userNFTs').add({
                    uid: state.user.uid,
                    nftId: nft.id,
                    name: nft.name,
                    image: nft.image,
                    price: nft.price,
                    timestamp: firebase.firestore.FieldValue.serverTimestamp()
                });
                
                await db.collection('users').doc(state.user.uid).update({
                    spotBalance: firebase.firestore.FieldValue.increment(-nft.price),
                    nftBalance: firebase.firestore.FieldValue.increment(nft.price)
                });
                
                showToast('NFT purchased successfully!', 'success');
            } catch (error) {
                showToast(error.message, 'error');
            }
        }

        async function loadUserNFTs() {
            db.collection('userNFTs').where('uid', '==', state.user.uid)
                .onSnapshot(snapshot => {
                    state.userNFTs = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
                    if (state.currentView === 'nft' && state.nftTab === 'sell') renderUserNFTs();
                });
        }

        function renderUserNFTs() {
            const container = document.getElementById('nft-list');
            if (state.userNFTs.length === 0) {
                container.innerHTML = '<p class="text-textGray text-center py-8">You don\'t own any NFTs yet</p>';
                return;
            }
            container.innerHTML = state.userNFTs.map(nft => `
                <div class="glass rounded-xl overflow-hidden">
                    <img src="${nft.image}" class="w-full h-32 object-cover">
                    <div class="p-3">
                        <h4 class="font-bold text-sm">${nft.name}</h4>
                        <p class="text-primary font-bold">₹${nft.price}</p>
                    </div>
                </div>
            `).join('');
        }

        // ==========================================
        // 👛 WALLET FUNCTIONS
        // ==========================================
        function switchWalletTab(tab) {
            document.querySelectorAll('.wallet-tab').forEach(t => {
                t.classList.remove('border-primary', 'text-white');
                t.classList.add('border-transparent', 'text-textGray');
            });
            event.target.classList.remove('border-transparent', 'text-textGray');
            event.target.classList.add('border-primary', 'text-white');
            
            document.querySelectorAll('.wallet-content').forEach(c => c.classList.add('hidden'));
            document.getElementById(`wallet-${tab}`).classList.remove('hidden');
        }

        function loadWalletData() {
            // Load wallet specific data
        }

        function updateTransferTo() {
            const from = document.getElementById('transfer-from').value;
            const toSelect = document.getElementById('transfer-to');
            toSelect.innerHTML = '';
            
            const accounts = [
                { value: 'spot', label: 'Spot Account' },
                { value: 'futures', label: 'Futures Account' },
                { value: 'margin', label: 'Margin Account' },
                { value: 'nft', label: 'NFT Account' },
                { value: 'invest', label: 'Invest Account' }
            ].filter(a => a.value !== from);
            
            accounts.forEach(acc => {
                toSelect.innerHTML += `<option value="${acc.value}">${acc.label}</option>`;
            });
            
            const balance = state.userData?.[from + 'Balance'] || 0;
            document.getElementById('transfer-available').textContent = balance.toFixed(2);
        }

        function swapTransferAccounts() {
            const from = document.getElementById('transfer-from').value;
            const to = document.getElementById('transfer-to').value;
            document.getElementById('transfer-from').value = to;
            updateTransferTo();
            document.getElementById('transfer-to').value = from;
        }

        async function executeTransfer() {
            const from = document.getElementById('transfer-from').value;
            const to = document.getElementById('transfer-to').value;
            const amount = parseFloat(document.getElementById('transfer-amount').value);
            
            if (!amount || amount <= 0) {
                showToast('Please enter valid amount', 'error');
                return;
            }
            
            const fromBalance = state.userData?.[from + 'Balance'] || 0;
            if (amount > fromBalance) {
                showToast('Insufficient balance', 'error');
                return;
            }
            
            try {
                const updates = {};
                updates[from + 'Balance'] = firebase.firestore.FieldValue.increment(-amount);
                updates[to + 'Balance'] = firebase.firestore.FieldValue.increment(amount);
                
                await db.collection('users').doc(state.user.uid).update(updates);
                
                await db.collection('transfers').add({
                    uid: state.user.uid,
                    from: from,
                    to: to,
                    amount: amount,
                    timestamp: firebase.firestore.FieldValue.serverTimestamp()
                });
                
                showToast('Transfer successful!', 'success');
                document.getElementById('transfer-amount').value = '';
            } catch (error) {
                showToast(error.message, 'error');
            }
        }

        // ==========================================
        // 👤 PROFILE FUNCTIONS
        // ==========================================
        function openEditProfile() {
            document.getElementById('edit-name').value = state.userData?.name || '';
            document.getElementById('edit-phone').value = state.userData?.phone || '';
            document.getElementById('edit-email').value = state.userData?.email || '';
            document.getElementById('edit-profile-modal').classList.add('show');
        }

        function closeEditProfile() {
            document.getElementById('edit-profile-modal').classList.remove('show');
        }

        async function saveProfile() {
            const name = document.getElementById('edit-name').value.trim();
            const phone = document.getElementById('edit-phone').value.trim();
            
            try {
                await db.collection('users').doc(state.user.uid).update({ name, phone });
                await auth.currentUser.updateProfile({ displayName: name });
                showToast('Profile updated!', 'success');
                closeEditProfile();
            } catch (error) {
                showToast(error.message, 'error');
            }
        }

        async function updateAvatar(input) {
            if (!input.files || !input.files[0]) return;
            
            try {
                const file = input.files[0];
                const storageRef = storage.ref(`avatars/${state.user.uid}`);
                await storageRef.put(file);
                const url = await storageRef.getDownloadURL();
                
                await db.collection('users').doc(state.user.uid).update({ avatar: url });
                await auth.currentUser.updateProfile({ photoURL: url });
                
                document.getElementById('profile-avatar').src = url;
                document.getElementById('menu-avatar').src = url;
                document.getElementById('wallet-avatar').src = url;
                
                showToast('Avatar updated!', 'success');
            } catch (error) {
                showToast(error.message, 'error');
            }
        }

        // ==========================================
        // 🛡️ KYC FUNCTIONS
        // ==========================================
        function previewKYCPhoto(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    document.getElementById('kyc-photo-preview').src = e.target.result;
                    document.getElementById('kyc-photo-preview').classList.remove('hidden');
                    document.getElementById('kyc-photo-icon').classList.add('hidden');
                    document.getElementById('kyc-photo-text').textContent = 'Photo selected';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        function previewKYCDocument(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    document.getElementById('kyc-document-preview').src = e.target.result;
                    document.getElementById('kyc-document-preview').classList.remove('hidden');
                    document.getElementById('kyc-document-icon').classList.add('hidden');
                    document.getElementById('kyc-document-text').textContent = 'Document selected';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        async function submitKYC() {
            const name = document.getElementById('kyc-name').value.trim();
            const phone = document.getElementById('kyc-phone').value.trim();
            const email = document.getElementById('kyc-email').value.trim();
            const docType = document.getElementById('kyc-document-type').value;
            const docNumber = document.getElementById('kyc-document-number').value.trim();
            
            if (!name || !phone || !email || !docType || !docNumber) {
                showToast('Please fill all required fields', 'error');
                return;
            }
            
            try {
                await db.collection('kyc').doc(state.user.uid).set({
                    uid: state.user.uid,
                    name, phone, email,
                    documentType: docType,
                    documentNumber: docNumber,
                    status: 'pending',
                    timestamp: firebase.firestore.FieldValue.serverTimestamp()
                });
                
                await db.collection('users').doc(state.user.uid).update({ kycStatus: 'pending' });
                
                showToast('KYC submitted for verification!', 'success');
                checkKYCStatus();
            } catch (error) {
                showToast(error.message, 'error');
            }
        }

        async function checkKYCStatus() {
            const doc = await db.collection('kyc').doc(state.user.uid).get();
            if (doc.exists) {
                const data = doc.data();
                document.getElementById('kyc-form-container').classList.add('hidden');
                document.getElementById('kyc-status-container').classList.remove('hidden');
                
                document.getElementById('kyc-status-text').textContent = data.status.charAt(0).toUpperCase() + data.status.slice(1);
                document.getElementById('kyc-submit-date').textContent = data.timestamp?.toDate().toLocaleDateString() || '-';
                document.getElementById('kyc-doc-type-display').textContent = data.documentType.toUpperCase();
                
                if (data.status === 'rejected') {
                    document.getElementById('kyc-reject-reason').classList.remove('hidden');
                    document.getElementById('kyc-reject-msg').textContent = data.rejectReason || 'Please resubmit with clear documents';
                    document.getElementById('kyc-resubmit-btn').classList.remove('hidden');
                    document.getElementById('kyc-status-icon').className = 'fas fa-times-circle text-4xl text-danger';
                } else if (data.status === 'verified') {
                    document.getElementById('kyc-status-icon').className = 'fas fa-check-circle text-4xl text-success';
                }
            }
        }

        function resubmitKYC() {
            document.getElementById('kyc-form-container').classList.remove('hidden');
            document.getElementById('kyc-status-container').classList.add('hidden');
        }

        // ==========================================
        // 📝 REPORT FUNCTIONS
        // ==========================================
        function handleReportFile(input) {
            if (input.files && input.files[0]) {
                document.getElementById('report-file-name').textContent = input.files[0].name;
                document.getElementById('report-file-name').classList.remove('hidden');
            }
        }

        async function submitReport() {
            const type = document.getElementById('report-type').value;
            const subject = document.getElementById('report-subject').value.trim();
            const description = document.getElementById('report-description').value.trim();
            
            if (!subject || !description) {
                showToast('Please fill all required fields', 'error');
                return;
            }
            
            try {
                await db.collection('reports').add({
                    uid: state.user.uid,
                    type, subject, description,
                    status: 'pending',
                    timestamp: firebase.firestore.FieldValue.serverTimestamp()
                });
                
                showToast('Report submitted successfully!', 'success');
                document.getElementById('report-subject').value = '';
                document.getElementById('report-description').value = '';
                loadPreviousReports();
            } catch (error) {
                showToast(error.message, 'error');
            }
        }

        async function loadPreviousReports() {
            const snapshot = await db.collection('reports').where('uid', '==', state.user.uid).orderBy('timestamp', 'desc').limit(5).get();
            const container = document.getElementById('previous-reports');
            
            if (snapshot.empty) {
                container.innerHTML = '<p class="text-textGray text-center py-4">No reports submitted</p>';
                return;
            }
            
            container.innerHTML = snapshot.docs.map(doc => {
                const data = doc.data();
                return `
                    <div class="glass rounded-lg p-3">
                        <div class="flex items-center justify-between mb-2">
                            <span class="font-semibold text-sm">${data.subject}</span>
                            <span class="text-xs ${data.status === 'resolved' ? 'text-success' : 'text-primary'}">${data.status}</span>
                        </div>
                        <p class="text-textGray text-xs">${data.type} - ${data.timestamp?.toDate().toLocaleDateString()}</p>
                    </div>
                `;
            }).join('');
        }

        // ==========================================
        // 🔔 NOTIFICATION FUNCTIONS
        // ==========================================
        async function loadNotifications() {
            db.collection('notifications').where('uid', '==', state.user.uid).orderBy('timestamp', 'desc').limit(20)
                .onSnapshot(snapshot => {
                    state.notifications = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
                    renderNotifications();
                });
        }

        function renderNotifications() {
            const container = document.getElementById('notification-list');
            const unread = state.notifications.filter(n => !n.read).length;
            
            document.getElementById('notif-badge').textContent = unread;
            document.getElementById('notif-badge').classList.toggle('hidden', unread === 0);
            
            if (state.notifications.length === 0) {
                container.innerHTML = '<p class="text-textGray text-center py-8">No notifications</p>';
                return;
            }
            
            container.innerHTML = state.notifications.map(notif => `
                <div class="glass rounded-lg p-3 ${notif.read ? '' : 'border-l-2 border-primary'}">
                    <p class="font-semibold text-sm">${notif.title}</p>
                    <p class="text-textGray text-xs">${notif.message}</p>
                    <p class="text-textGray text-xs mt-1">${notif.timestamp?.toDate().toLocaleString()}</p>
                </div>
            `).join('');
        }

        // ==========================================
        // 🔔 TOAST FUNCTION
        // ==========================================
        function showToast(message, type = 'info') {
            const toast = document.getElementById('toast');
            toast.textContent = message;
            toast.className = 'toast show';
            if (type === 'error') toast.classList.add('error');
            if (type === 'success') toast.classList.add('success');
            
            setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            // Close modals on outside click
            document.querySelectorAll('.modal-overlay').forEach(modal => {
                modal.addEventListener('click', e => {
                    if (e.target === modal) modal.classList.remove('show');
                });
            });
        });
    </script>
</body>
</html>
